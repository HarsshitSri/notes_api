POSTGRES_DB=notes_db
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=notes_pass
# Prefer 32+ characters. The API derives a 256-bit signing key, so shorter values still work.
JWT_SECRET=this-is-a-very-long-secret-key-for-jwt-signing-32chars-min
JWT_EXPIRATION=86400000

# Comma-separated browser origins allowed to call the API (Vercel UI).
# Leave empty locally to allow http://localhost:* and http://127.0.0.1:*
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Neon (Railway production) example — do not commit real secrets:
# SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# SPRING_DATASOURCE_USERNAME=neondb_owner
# SPRING_DATASOURCE_PASSWORD=replace-me
